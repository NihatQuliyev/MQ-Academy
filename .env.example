# Neon PostgreSQL — "Pooled connection" URL-ini buraya yaz
DATABASE_URL="postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Neon PostgreSQL — "Direct connection" URL-ini buraya yaz (migration üçün)
DIRECT_URL="postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Güclü random secret — `openssl rand -hex 32` ilə generasiya et
NEXTAUTH_SECRET="your-32-char-random-secret-here"

# Production domain-in (https ilə)
NEXTAUTH_URL="https://mq-akademiya.vercel.app"

# Vercel Blob — Vercel dashboard-dan al (Storage > Blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxx"
